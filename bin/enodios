#!/usr/bin/env bash
# Enodios — Hermes Agent + vLLM local stack (Ἐνόδιος: Hermes of the road).
set -euo pipefail

ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
DATA="${ENODIOS_DATA:-$HOME/.local/share/enodios}"
VENV="${ENODIOS_VENV:-$DATA/.venv}"
PORT="${ENODIOS_PORT:-8000}"
MODEL="${ENODIOS_MODEL:-solidrust/Hermes-3-Llama-3.1-8B-AWQ}"
SERVED_NAME="${ENODIOS_SERVED_NAME:-hermes3:8b}"
MAX_LEN="${ENODIOS_MAX_MODEL_LEN:-65536}"
GPU_UTIL="${ENODIOS_GPU_UTIL:-0.75}"
KV_CACHE_DTYPE="${ENODIOS_KV_CACHE_DTYPE:-fp8}"
PROVIDER_NAME="${ENODIOS_PROVIDER:-enodios}"
HERMES_CONFIG="${HERMES_CONFIG:-$HOME/.hermes/config.yaml}"
LOG_FILE="${ENODIOS_LOG:-$DATA/vllm.log}"
PID_FILE="${ENODIOS_PID_FILE:-$DATA/vllm.pid}"

usage() {
  cat <<EOF
Enodios — local Hermes Agent + vLLM (Hermes of the road)

Usage: enodios <command>

Commands:
  install     Install uv venv + vLLM, link this CLI to ~/.local/bin
  start       Run vLLM (foreground by default; -b/--background to detach)
  stop        Stop vLLM processes for this stack
  doctor      Check GPU, CUDA, venv, and endpoint health
  recommend   Detect GPU VRAM and suggest model/settings for Hermes Agent
  bench       Tool-call latency test against vLLM
  configure   Point Hermes config at vLLM (local or remote URL)
  urls        Print vLLM API URLs (local + LAN for distributed Hermes)
  status      Show vLLM /v1/models status
  help        Show this help

Environment:
  ENODIOS_DATA, ENODIOS_VENV, ENODIOS_PORT, ENODIOS_MODEL
  ENODIOS_GPU_UTIL, ENODIOS_MAX_MODEL_LEN, ENODIOS_PROVIDER
  ENODIOS_LOG, ENODIOS_PID_FILE

  vLLM binds 127.0.0.1 by default; use "start --lan" to expose on the LAN (no API auth)

Docs: https://dataknifeai.github.io/enodios/
Repo: https://github.com/DataKnifeAI/enodios
EOF
}

require_linux() {
  [[ "$(uname -s)" == Linux ]] || { echo "ERROR: Linux only"; exit 1; }
}

require_gpu() {
  if ! command -v nvidia-smi &>/dev/null; then
    echo "WARN: nvidia-smi not found — GPU inference will not work"
    return 1
  fi
  nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader
}

ensure_uv() {
  if command -v uv &>/dev/null; then
    return 0
  fi
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="$HOME/.local/bin:$PATH"
  command -v uv &>/dev/null || { echo "ERROR: uv install failed"; exit 1; }
}

link_cli() {
  mkdir -p "$HOME/.local/bin"
  ln -sf "$ROOT/bin/enodios" "$HOME/.local/bin/enodios"
  echo "Linked: $HOME/.local/bin/enodios"
}

cmd_install() {
  require_linux
  echo "== GPU =="
  require_gpu || true
  ensure_uv
  mkdir -p "$DATA"
  echo "== vLLM venv ($VENV) =="
  if [[ ! -x "$VENV/bin/python" ]]; then
    uv venv --python 3.12 --seed --managed-python "$VENV"
  else
    echo "venv exists — upgrading packages"
  fi
  # shellcheck disable=SC1091
  source "$VENV/bin/activate"
  uv pip install vllm --torch-backend=auto
  python -c "import torch; assert torch.cuda.is_available(), 'CUDA not available to PyTorch'"
  link_cli
  if [[ -d /opt/cuda/bin ]] && ! grep -q 'CUDA_HOME=/opt/cuda' "$HOME/.bashrc" 2>/dev/null; then
    cat >> "$HOME/.bashrc" <<'EOF'

# enodios: CUDA toolkit for FlashInfer JIT (optional)
export CUDA_HOME=/opt/cuda
export PATH="$CUDA_HOME/bin:$PATH"
EOF
    echo "Appended CUDA_HOME hints to ~/.bashrc (optional FlashInfer speedup)"
  fi
  echo ""
  echo "Done. Next:"
  echo "  enodios recommend  # GPU → model/settings for Hermes Agent"
  echo "  enodios doctor"
  echo "  enodios start -b   # background (or foreground in another terminal)"
  echo "  enodios configure"
  echo "  hermes chat"
}

require_venv() {
  if [[ ! -x "$VENV/bin/vllm" ]]; then
    echo "ERROR: vLLM not installed. Run: enodios install"
    exit 1
  fi
}

vllm_env() {
  export VLLM_USE_FLASHINFER_SAMPLER=0
  if [[ -n "${CUDA_HOME:-}" ]] && [[ -x "${CUDA_HOME}/bin/nvcc" ]]; then
    unset VLLM_USE_FLASHINFER_SAMPLER
  fi
}

lan_ip() {
  ip -4 route get 1.1.1.1 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i == "src") { print $(i + 1); exit }}' \
    || hostname -I 2>/dev/null | awk '{print $1}' \
    || true
}

vllm_local_base() {
  echo "http://127.0.0.1:${PORT}/v1"
}

vllm_lan_base() {
  local ip
  ip="$(lan_ip)"
  [[ -n "$ip" ]] && echo "http://${ip}:${PORT}/v1"
}

vllm_ready() {
  curl -sf --max-time 2 "$(vllm_local_base)/models" &>/dev/null
}

vllm_lan_bound() {
  ss -ltnH 2>/dev/null | grep -qE "0\.0\.0\.0:${PORT}[[:space:]]"
}

start_usage() {
  cat <<EOF
Usage: enodios start [-b|--background] [-l|--lan]

  (default)   Bind 127.0.0.1 only (local Hermes on this machine)
  -l, --lan   Bind 0.0.0.0 — expose vLLM on the LAN for remote Hermes agents
  -b, --background   Detach; logs to \$ENODIOS_LOG (default: $LOG_FILE)

  Distributed Hermes: GPU host runs "enodios start -b --lan"; controller runs
  "enodios configure --url http://<gpu-host>:${PORT}/v1"
EOF
}

configure_usage() {
  cat <<EOF
Usage: enodios configure [--url BASE_URL] [--lan]

  (default)   http://127.0.0.1:${PORT}/v1 — Hermes on the same machine as vLLM
  --url URL   Custom OpenAI base URL (remote GPU / Hermes-controlling-Hermes)
  --lan       Use this machine's LAN IP (GPU host; remote agents use urls output)
EOF
}

normalize_base_url() {
  local u="${1%/}"
  [[ "$u" == */v1 ]] || u="${u}/v1"
  echo "$u"
}

print_lan_warning() {
  echo "WARN: LAN mode — no API auth. Trusted local network only."
}

prepare_vllm() {
  require_venv
  # shellcheck disable=SC1091
  source "$VENV/bin/activate"
  vllm_env
  extra_args=()
  [[ -n "$KV_CACHE_DTYPE" ]] && extra_args+=(--kv-cache-dtype "$KV_CACHE_DTYPE")
}

cmd_start() {
  local background=0
  local bind_host="127.0.0.1"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -b|--background) background=1; shift ;;
      -l|--lan) bind_host="0.0.0.0"; shift ;;
      -h|--help) start_usage; return 0 ;;
      *) echo "Unknown option: $1"; start_usage; exit 1 ;;
    esac
  done

  if vllm_ready; then
    echo "vLLM already running on $(vllm_local_base)"
    [[ -f "$PID_FILE" ]] && echo "pid: $(cat "$PID_FILE")"
    cmd_urls 2>/dev/null || true
    return 0
  fi

  prepare_vllm
  echo "Starting vLLM on ${bind_host}:${PORT} (model=${SERVED_NAME}, context=${MAX_LEN})"
  echo "Local API: $(vllm_local_base)"
  if [[ "$bind_host" == "0.0.0.0" ]]; then
    print_lan_warning
    local lan
    lan="$(vllm_lan_base)"
    [[ -n "$lan" ]] && echo "LAN API:   ${lan}"
  fi

  if [[ "$background" -eq 0 ]]; then
    exec vllm serve "$MODEL" \
      --host "$bind_host" \
      --port "$PORT" \
      --max-model-len "$MAX_LEN" \
      --gpu-memory-utilization "$GPU_UTIL" \
      --quantization awq \
      --enable-auto-tool-choice \
      --tool-call-parser hermes \
      --served-model-name "$SERVED_NAME" \
      --no-enable-flashinfer-autotune \
      "${extra_args[@]}"
  fi

  mkdir -p "$DATA"
  nohup vllm serve "$MODEL" \
    --host "$bind_host" \
    --port "$PORT" \
    --max-model-len "$MAX_LEN" \
    --gpu-memory-utilization "$GPU_UTIL" \
    --quantization awq \
    --enable-auto-tool-choice \
    --tool-call-parser hermes \
    --served-model-name "$SERVED_NAME" \
    --no-enable-flashinfer-autotune \
    "${extra_args[@]}" >>"$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" >"$PID_FILE"
  echo "Background pid: $pid"
  echo "Log: $LOG_FILE"

  for _ in $(seq 1 90); do
    if vllm_ready; then
      echo "Ready: $(vllm_local_base)"
      if [[ "$bind_host" == "0.0.0.0" ]]; then
        local lan
        lan="$(vllm_lan_base)"
        [[ -n "$lan" ]] && echo "LAN:   ${lan}"
        echo "Remote Hermes: enodios configure --url ${lan:-http://<this-host>:${PORT}/v1}"
      fi
      return 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
      echo "ERROR: vLLM exited during startup. Last log lines:"
      tail -20 "$LOG_FILE" 2>/dev/null || true
      rm -f "$PID_FILE"
      return 1
    fi
    sleep 2
  done

  echo "WARN: still starting after 3m — check: tail -f $LOG_FILE"
  return 0
}

cmd_stop() {
  if [[ -f "$PID_FILE" ]]; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
  fi
  pkill -f "${VENV}/bin/vllm serve" 2>/dev/null || true
  pkill -f 'vllm serve.*hermes3:8b' 2>/dev/null || true
  sleep 1
  if vllm_ready; then
    echo "WARN: port ${PORT} still responding"
  else
    echo "vLLM stopped (port ${PORT} down)"
  fi
}

cmd_recommend() {
  python3 - "$@" <<'PY'
import json, os, shutil, subprocess, sys

HERMES_MIN_CTX = 65536
DATA = os.path.expanduser(os.environ.get("ENODIOS_DATA", os.path.expanduser("~/.local/share/enodios")))

def query_gpu():
    if not shutil.which("nvidia-smi"):
        return None
    r = subprocess.run(
        [
            "nvidia-smi",
            "--query-gpu=index,name,memory.total,memory.free,memory.used",
            "--format=csv,noheader,nounits",
        ],
        capture_output=True,
        text=True,
    )
    if r.returncode != 0 or not r.stdout.strip():
        return None
    rows = []
    for line in r.stdout.strip().splitlines():
        idx, name, total, free, used = [x.strip() for x in line.split(",")]
        rows.append(
            {
                "index": int(idx),
                "name": name,
                "total_mib": int(total),
                "free_mib": int(free),
                "used_mib": int(used),
            }
        )
    return rows

def other_compute_vram():
    r = subprocess.run(
        [
            "nvidia-smi",
            "--query-compute-apps=pid,process_name,used_gpu_memory",
            "--format=csv,noheader,nounits",
        ],
        capture_output=True,
        text=True,
    )
    apps = []
    if r.returncode == 0:
        for line in r.stdout.strip().splitlines():
            if not line.strip():
                continue
            parts = [p.strip() for p in line.split(",")]
            if len(parts) >= 3:
                apps.append(
                    {
                        "pid": parts[0],
                        "name": parts[1],
                        "vram_mib": int(parts[2]) if parts[2].isdigit() else 0,
                    }
                )
    return apps

def pick_profile(total_mib, free_mib, shared_gpu):
    awq = {
        "model": "solidrust/Hermes-3-Llama-3.1-8B-AWQ",
        "served_name": "hermes3:8b",
        "quantization": "awq",
        "kv_cache_dtype": "fp8",
        "context_length": HERMES_MIN_CTX,
        "tool_parser": "hermes",
        "uncensored": True,
        "tools": True,
    }

    if total_mib < 8000:
        return {
            **awq,
            "tier": "unsupported",
            "gpu_util": None,
            "context_length": HERMES_MIN_CTX,
            "feasible": False,
            "summary": "GPU VRAM too small for Hermes Agent at 64k context.",
            "notes": [
                "Hermes Agent needs at least 64k context for reliable tool loops.",
                "Use a cloud provider in Hermes, or a GPU with 12GB+ VRAM.",
            ],
        }

    if total_mib < 12000:
        return {
            **awq,
            "tier": "8gb-class",
            "gpu_util": 0.92,
            "feasible": False,
            "summary": "10–12GB GPUs usually cannot hold Hermes 3 8B AWQ at 64k.",
            "notes": [
                "You may get OOM even with fp8 KV cache and max GPU util.",
                "Upgrade to 16GB+ VRAM, or use Hermes with a cloud API.",
            ],
        }

    if total_mib < 16000:
        util = 0.90 if free_mib >= 10000 and not shared_gpu else 0.82
        return {
            **awq,
            "tier": "12gb-class",
            "gpu_util": util,
            "feasible": free_mib >= 9000,
            "summary": "12GB VRAM: Hermes 3 8B AWQ at 64k is tight but often works.",
            "notes": [
                "Close browsers, games, and Ollama before starting.",
                "First start may take 1–2 minutes while weights download.",
            ],
        }

    if total_mib < 22000:
        util = 0.80 if free_mib >= 14000 and not shared_gpu else 0.70
        return {
            **awq,
            "tier": "16gb-class",
            "gpu_util": util,
            "feasible": free_mib >= 11000,
            "summary": "16GB VRAM: good fit for Hermes 3 8B AWQ + 64k agent context.",
            "notes": [
                "Close other GPU apps if startup reports insufficient memory.",
            ],
        }

    util = 0.75 if free_mib >= 18000 and not shared_gpu else 0.65
    profile = {
        **awq,
        "tier": "24gb-class",
        "gpu_util": util,
        "feasible": free_mib >= 14000,
        "summary": "24GB VRAM: ideal for Enodios defaults (fast uncensored Hermes agent).",
        "notes": [
            "Measured ~20GB VRAM at 64k + fp8 KV on RTX 4090.",
        ],
    }
    if total_mib >= 40000 and free_mib >= 30000:
        profile["alt_model"] = "NousResearch/Hermes-3-Llama-3.1-8B"
        profile["alt_notes"] = (
            "BF16 weights need ~16GB+ free; 64k KV may still not fit — try only on a clean GPU."
        )
    return profile

def shell_exports(profile):
    lines = [
        f'export ENODIOS_MODEL="{profile["model"]}"',
        f'export ENODIOS_SERVED_NAME="{profile["served_name"]}"',
        f'export ENODIOS_MAX_MODEL_LEN={profile["context_length"]}',
        f'export ENODIOS_KV_CACHE_DTYPE={profile["kv_cache_dtype"]}',
    ]
    if profile.get("gpu_util") is not None:
        lines.append(f'export ENODIOS_GPU_UTIL={profile["gpu_util"]}')
    return lines

def write_env_file(profile, path):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write("# Generated by: enodios recommend --apply\n")
        for line in shell_exports(profile):
            f.write(line + "\n")
    return path

args = sys.argv[1:]
shell_only = "--shell" in args
json_only = "--json" in args
apply = "--apply" in args

gpus = query_gpu()
if not gpus:
    print("ERROR: nvidia-smi not found or no NVIDIA GPU detected.", file=sys.stderr)
    print("Hermes Agent local inference requires an NVIDIA GPU + driver.", file=sys.stderr)
    sys.exit(1)

gpu = gpus[0]
apps = other_compute_vram()
shared = gpu["used_mib"] > 2048 or len(apps) > 0
profile = pick_profile(gpu["total_mib"], gpu["free_mib"], shared)
profile["gpu"] = gpu
profile["shared_gpu"] = shared
profile["compute_apps"] = apps
profile["hermes_min_context"] = HERMES_MIN_CTX

if json_only:
    print(json.dumps(profile, indent=2))
    sys.exit(0 if profile.get("feasible", True) else 2)

if shell_only:
    if not profile.get("feasible", True):
        print("# WARNING: current free VRAM may be too low — close GPU apps first", file=sys.stderr)
    for line in shell_exports(profile):
        print(line)
    sys.exit(0 if profile.get("feasible", True) else 2)

if apply:
    path = write_env_file(profile, os.path.join(DATA, "recommended.env"))
    print(f"Wrote {path}")
    print("  source ~/.local/share/enodios/recommended.env")
    print("  enodios start -b && enodios configure && hermes chat")

print("== GPU ==")
print(f"device:     {gpu['name']} (cuda:{gpu['index']})")
print(f"vram total: {gpu['total_mib']} MiB")
print(f"vram free:  {gpu['free_mib']} MiB")
print(f"vram used:  {gpu['used_mib']} MiB")
if shared:
    print("status:     shared (other processes using GPU)")
    for app in apps[:5]:
        print(f"  - pid {app['pid']} {app['name']}: {app['vram_mib']} MiB")
else:
    print("status:     mostly idle")
print()

print("== Hermes Agent requirements ==")
print(f"  context_length >= {HERMES_MIN_CTX} (agent tool loops)")
print("  model with native tool calling + hermes parser")
print("  Hermes CLI: hermes setup && enodios configure")
print()

print("== Recommendation ==")
print(f"tier:    {profile['tier']}")
print(f"summary: {profile['summary']}")
print(f"feasible now: {'yes' if profile.get('feasible', True) else 'no — free more VRAM'}")
print()
print("model:       ", profile["model"])
print("served name: ", profile["served_name"])
print("context:     ", profile["context_length"])
print("kv cache:    ", profile["kv_cache_dtype"])
if profile.get("gpu_util") is not None:
    print("gpu util:    ", profile["gpu_util"])
print("tools:       ", "yes" if profile["tools"] else "no")
print("uncensored:  ", "yes" if profile["uncensored"] else "no")
print()

for note in profile.get("notes", []):
    print(f"  • {note}")
if profile.get("alt_model"):
    print()
    print(f"optional (higher quality, tighter VRAM): {profile['alt_model']}")
    print(f"  {profile.get('alt_notes', '')}")
print()

print("== Apply settings ==")
print("Copy/paste before enodios start:")
print()
for line in shell_exports(profile):
    print(line)
print()
print("Or persist:")
print("  enodios recommend --apply")
print("  source ~/.local/share/enodios/recommended.env")
print()
print("Then:")
print("  enodios install   # if not done")
print("  enodios start -b")
print("  enodios configure")
print("  hermes chat")

sys.exit(0 if profile.get("feasible", True) else 2)
PY
}

recommend_usage() {
  cat <<EOF
Usage: enodios recommend [--shell|--json|--apply]

  Detect GPU VRAM and suggest model/settings for Hermes Agent (64k context).

  --shell   Print export commands only (eval: eval "\$(enodios recommend --shell)")
  --json    Machine-readable output
  --apply   Write ~/.local/share/enodios/recommended.env
EOF
}

cmd_doctor() {
  echo "== enodios =="
  echo "data:  $DATA"
  echo "venv:  $VENV"
  echo "port:  $PORT"
  echo "bind:  127.0.0.1 (default loopback; start --lan → 0.0.0.0)"
  echo "model: $MODEL -> $SERVED_NAME"
  echo ""
  echo "== GPU =="
  require_gpu || true
  echo "Tip: enodios recommend — GPU-specific model/settings for Hermes Agent"
  echo ""
  echo ""
  echo "== CUDA toolkit =="
  if command -v nvcc &>/dev/null; then
    nvcc --version | tail -1
  elif [[ -x /opt/cuda/bin/nvcc ]]; then
    echo "nvcc at /opt/cuda/bin/nvcc (not in PATH — set CUDA_HOME=/opt/cuda)"
  else
    echo "nvcc not found (OK — PyTorch sampler fallback enabled)"
  fi
  echo ""
  echo "== vLLM venv =="
  if [[ -x "$VENV/bin/vllm" ]]; then
    echo "OK: $VENV/bin/vllm"
    # shellcheck disable=SC1091
    source "$VENV/bin/activate"
    python -c "import torch; print('torch', torch.__version__, 'cuda', torch.cuda.is_available())"
  else
    echo "MISSING: run enodios install"
  fi
  echo ""
  echo "== Hermes =="
  if command -v hermes &>/dev/null; then
    echo "OK: $(command -v hermes)"
  else
    echo "hermes CLI not found — install: https://github.com/NousResearch/hermes-agent"
  fi
  echo ""
  echo "== Endpoint =="
  if vllm_ready; then
    cmd_urls
    echo ""
    curl -sf --max-time 3 "$(vllm_local_base)/models" | python3 -m json.tool 2>/dev/null | head -15
    if vllm_lan_bound; then
      echo ""
      print_lan_warning
    fi
  else
    echo "vLLM not running on port ${PORT} (enodios start)"
  fi
}

cmd_urls() {
  echo "local: $(vllm_local_base)"
  if vllm_lan_bound; then
    local lan
    lan="$(vllm_lan_base)"
    if [[ -n "$lan" ]]; then
      echo "lan:   ${lan}"
      echo "remote hermes: enodios configure --url ${lan}"
    else
      echo "lan:   bound on 0.0.0.0 (could not detect LAN IP for --url)"
    fi
  else
    echo "lan:   not exposed (default loopback — use: enodios start --lan)"
  fi
}

cmd_bench() {
  python3 <<PY
import json, subprocess, time, sys
url = "$(vllm_local_base)/chat/completions"
model = "${SERVED_NAME}"
tool = [{"type":"function","function":{"name":"calculator","description":"add","parameters":{"type":"object","properties":{"a":{"type":"number"},"b":{"type":"number"}},"required":["a","b"]}}}]
payload = {"model":model,"messages":[{"role":"user","content":"calculator a=2 b=2"}],"tools":tool,"tool_choice":"required","max_tokens":80,"temperature":0}
t0 = time.time()
r = subprocess.run(["curl","-s",url,"-H","Content-Type: application/json","-d",json.dumps(payload)],capture_output=True,text=True)
dt = time.time()-t0
try:
    d = json.loads(r.stdout)
    tc = d["choices"][0]["message"].get("tool_calls")
    print(f"latency={dt:.2f}s tool_calls={bool(tc)}")
    if tc: print(json.dumps(tc[0], indent=2))
    sys.exit(0 if tc else 1)
except Exception as e:
    print("FAIL:", e, r.stdout[:300])
    sys.exit(1)
PY
}

cmd_configure() {
  local base_url=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url)
        [[ $# -ge 2 ]] || { echo "ERROR: --url requires an argument"; configure_usage; exit 1; }
        base_url="$2"
        shift 2
        ;;
      --lan)
        local ip
        ip="$(lan_ip)"
        [[ -n "$ip" ]] || { echo "ERROR: could not detect LAN IP"; exit 1; }
        base_url="http://${ip}:${PORT}/v1"
        shift
        ;;
      -h|--help) configure_usage; return 0 ;;
      *) echo "Unknown option: $1"; configure_usage; exit 1 ;;
    esac
  done
  [[ -n "$base_url" ]] || base_url="$(vllm_local_base)"
  base_url="$(normalize_base_url "$base_url")"

  mkdir -p "$(dirname "$HERMES_CONFIG")"
  if [[ ! -f "$HERMES_CONFIG" ]]; then
    echo "ERROR: $HERMES_CONFIG not found — run hermes setup first"
    exit 1
  fi
  cp -a "$HERMES_CONFIG" "${HERMES_CONFIG}.bak.$(date +%Y%m%d%H%M%S)"
  python3 <<PY
from pathlib import Path
import re
path = Path("${HERMES_CONFIG}")
text = path.read_text()
provider = "${PROVIDER_NAME}"
model = "${SERVED_NAME}"
ctx = ${MAX_LEN}
base = "${base_url}"

# model block
text = re.sub(r"(?m)^  default:.*", f"  default: {model}", text, count=1)
text = re.sub(r"(?m)^  provider:.*", f"  provider: custom:{provider}", text, count=1)
text = re.sub(r"(?m)^  context_length:.*", f"  context_length: {ctx}", text, count=1)

block = f"""  - name: {provider}
    base_url: {base}
    models:
      {model}:
        context_length: {ctx}
"""
if "custom_providers:" not in text:
    text += f"\ncustom_providers:\n{block}"
else:
    # replace or append provider entry
    pat = rf"(?ms)  - name: {re.escape(provider)}\n.*?(?=\n  - name:|\nz|\n#|\nfallback_providers:|\n[a-z_]+:)"
    if re.search(pat, text):
        text = re.sub(pat, block.rstrip() + "\n", text)
    else:
        text = text.replace("custom_providers:\n", f"custom_providers:\n{block}", 1)

path.write_text(text)
print(f"Updated {path}")
print(f"  provider: custom:{provider}")
print(f"  base_url: {base}")
print(f"  model:    {model}")
PY
  echo "Backup saved alongside config. Run: hermes chat"
}

cmd_status() {
  if ! vllm_ready; then
    echo "down"
    return 1
  fi
  [[ -f "$PID_FILE" ]] && echo "pid: $(cat "$PID_FILE")"
  cmd_urls
  echo ""
  curl -sf "$(vllm_local_base)/models" | python3 -m json.tool 2>/dev/null
}

main() {
  case "${1:-help}" in
    install) cmd_install ;;
    start) shift; cmd_start "$@" ;;
    stop) cmd_stop ;;
    doctor) cmd_doctor ;;
    recommend)
      shift
      case "${1:-}" in
        -h|--help) recommend_usage ;;
        *) cmd_recommend "$@" ;;
      esac
      ;;
    bench) cmd_bench ;;
    configure) shift; cmd_configure "$@" ;;
    urls) cmd_urls ;;
    status) cmd_status ;;
    help|-h|--help) usage ;;
    *) echo "Unknown command: $1"; usage; exit 1 ;;
  esac
}

main "$@"
